            </property>
            <property key="labelText" type="string" required="false" defaultValue="Label">
                <caption>Label Text</caption>
                <description>입력창 위에 표시될 라벨 텍스트입니다.</description>
            </property>
            <property key="placeholderText" type="string" required="false" defaultValue="Enter value...">
